generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────

enum UserRole {
  super_admin
  school_admin
  director
  branch_admin      // Filial boshqaruvchisi — faqat o'z filialini ko'radi
  vice_principal
  teacher
  class_teacher
  accountant
  librarian
  student
  parent
}

enum SubscriptionPlan {
  free
  basic
  standard
  premium
}

enum BillingCycle {
  monthly
  yearly
}

enum SubscriptionStatus {
  active
  inactive
  trial
  expired
  cancelled
}

enum ModuleName {
  auth
  users
  classes
  schedule
  notifications
  messaging
  reports
  attendance
  grades
  payments
  exams
  homework
  display
  finance_dashboard
  learning_center
  canteen
  library
  transport
  inventory
  psychology
  clubs
}

enum ClubCategory {
  sport
  art
  science
  music
  tech
  language
  other
}

enum ClubRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Course Scope (O'quv kurs ko'rinishi) ─────────────────────────────────
enum CourseScope {
  GLOBAL  // Barcha filiallar uchun ko'rinadigan markaziy kurs
  LOCAL   // Faqat yaratilgan filial uchun
}

// ─── Finance Type (Maktab moliya rejimi) ──────────────────────────────────
enum FinanceType {
  CENTRALIZED    // Barcha filiallar bitta markaziy g'azna orqali
  DECENTRALIZED  // Har bir filial mustaqil g'azna boshqaradi
}

// ─── Treasury Type ────────────────────────────────────────────────────────
enum TreasuryType {
  CASH   // Naqd pul kassasi
  BANK   // Bank hisob raqami
}

// ─── Financial Shift Status ───────────────────────────────────────────────
enum ShiftStatus {
  OPEN    // Smena ochiq (to'lovlar qabul qilinmoqda)
  CLOSED  // Smena yopilgan (kunlik hisob-kitob tugagan)
}

// ─── CRM: Lead manba (qayerdan keldi) ─────────────────────────────────────
enum LeadSource {
  INSTAGRAM    // Instagram reklama / DM
  TELEGRAM     // Telegram kanal / bot
  FACEBOOK     // Facebook reklama
  WEBSITE      // Rasmiy sayt orqali
  REFERRAL     // Do'st/tanish tavsiyasi
  CALL         // Telefon qo'ng'irog'i
  WALK_IN      // To'g'ridan-to'g'ri kelib
  OTHER        // Boshqa manba
}

// ─── CRM: Lead holati (voronka bosqichi) ───────────────────────────────────
enum LeadStatus {
  NEW              // Yangi lead — hali bog'lanilmagan
  CONTACTED        // Bog'lanildi — muloqot boshlandi
  TEST_LESSON      // Sinov darsiga keldi
  WAITING_PAYMENT  // To'lov kutilmoqda (deyarli tayyor)
  CONVERTED        // O'quvchiga aylantirildi ✅
  CLOSED           // Yopildi (rad etdi / aloqa yo'q)
}

enum AttendanceStatus {
  present
  absent
  late
  excused
}

enum GradeType {
  homework
  classwork
  test
  exam
  quarterly
  final
}

enum ExamFrequency {
  weekly
  monthly
  quarterly
  final
  on_demand
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
  overdue
}

enum PaymentProvider {
  payme
  click
  uzum
  cash
}

enum NotificationChannel {
  sms
  email
  push
  in_app
}

enum DayOfWeek {
  monday
  tuesday
  wednesday
  thursday
  friday
  saturday
  sunday
}

enum AuditAction {
  create
  update
  delete
  login
  logout
  export
}

enum Language {
  uz
  ru
}

// ─── Schools ──────────────────────────────────────────────────────────────

model School {
  id               String           @id @default(uuid())
  name             String
  slug             String           @unique
  address          String?
  phone            String?
  email            String?
  logoUrl          String?
  isActive         Boolean          @default(true)
  subscriptionTier SubscriptionPlan @default(free)
  financeType      FinanceType      @default(CENTRALIZED)   // Moliya rejimi
  timezone         String           @default("Asia/Tashkent") // IANA timezone — UTC saqlash uchun
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  users         User[]
  classes       Class[]
  subjects      Subject[]
  schedules     Schedule[]
  attendance    Attendance[]
  grades        Grade[]
  exams         Exam[]
  payments      Payment[]
  modules       SchoolModule[]
  notifications Notification[]
  messages      Message[]
  conversations Conversation[]
  auditLogs     AuditLog[]
  subscription  Subscription?
  feeStructures FeeStructure[]
  menuDays      MenuDay[]
  libraryBooks  LibraryBook[]
  libraryLoans  LibraryLoan[]
  homeworks        Homework[]
  leaveRequests    LeaveRequest[]
  staffSalaries    StaffSalary[]
  salaryAdvances   SalaryAdvance[]
  monthlyPayrolls  MonthlyPayroll[]
  payrollItems     PayrollItem[]
  academicEvents   AcademicEvent[]
  disciplineIncidents DisciplineIncident[]
  parentMeetings   ParentMeeting[]
  examSessions     ExamSession[]
  transportRoutes  TransportRoute[]
  transportStudents TransportStudent[]
  courses          Course[]
  courseEnrollments CourseEnrollment[]
  systemConfigs    SystemConfig[]
  clubs            Club[]
  branches         Branch[]          // Multi-branch support
  treasuries       Treasury[]        // G'azna kassalari
  financialShifts  FinancialShift[]  // Smena jurnali
  rooms            Room[]            // Xonalar (filial bo'yicha)
  courseMaterials  CourseMaterial[]  // Markaziy o'quv materiallari
  leads            Lead[]            // CRM leadlar
  leadComments     LeadComment[]
  coinTransactions CoinTransaction[]
  coinShopItems    CoinShopItem[]

  @@map("schools")
}

// ─── Branches ─────────────────────────────────────────────────────────────

model Branch {
  id          String   @id @default(uuid())
  schoolId    String
  name        String                    // "Chilonzor filiali", "Yunusobod filiali"
  code        String?                   // Qisqa kod: "CHI", "YUN" (ixtiyoriy)
  address     String?
  phone       String?
  email       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school      School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  users       User[]
  classes     Class[]
  attendance  Attendance[]
  grades      Grade[]
  payments    Payment[]
  leaveRequests LeaveRequest[]
  staffSalaries StaffSalary[]
  courses     Course[]
  clubs       Club[]
  transportRoutes TransportRoute[]
  modules         BranchModule[]
  userAssignments UserBranchAssignment[]
  treasuries      Treasury[]
  financialShifts FinancialShift[]
  rooms           Room[]
  schedules       Schedule[]
  leads           Lead[]        // CRM leadlar (filial kesimi)

  @@unique([schoolId, name])
  @@index([schoolId])
  @@map("branches")
}

// ─── Branch Modules (Filial darajasida feature flags) ─────────────────────

model BranchModule {
  id         String     @id @default(uuid())
  branchId   String
  moduleName ModuleName
  isEnabled  Boolean    @default(false)
  configJson Json?                       // Filialga xos konfiguratsiya
  updatedAt  DateTime   @updatedAt
  updatedBy  String?

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, moduleName])
  @@index([branchId])
  @@map("branch_modules")
}

// ─── User-Branch Assignment (multi-branch staff) ──────────────────────────
// Teacher/staff may belong to multiple branches simultaneously.
// user.branchId = asosiy (default) filial; bu jadval qo'shimcha filiallarni belgilaydi.

model UserBranchAssignment {
  id        String   @id @default(uuid())
  userId    String
  branchId  String
  role      UserRole // Bu filial uchun roli (asosiy roldan farq qilishi mumkin)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId])
  @@index([userId])
  @@index([branchId])
  @@map("user_branch_assignments")
}

// ─── Subscriptions ────────────────────────────────────────────────────────

model Subscription {
  id          String             @id @default(uuid())
  schoolId    String             @unique
  plan        SubscriptionPlan   @default(basic)
  billingCycle BillingCycle      @default(monthly)
  status      SubscriptionStatus @default(trial)
  nextBilling DateTime?
  trialEndsAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ─── School Modules ───────────────────────────────────────────────────────

model SchoolModule {
  id         String     @id @default(uuid())
  schoolId   String
  moduleName ModuleName
  isEnabled  Boolean    @default(false)
  configJson Json?
  updatedAt  DateTime   @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, moduleName])
  @@map("school_modules")
}

// ─── Users ────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  schoolId     String?
  branchId     String?  // NULL = barcha filiallarga tegishli (director, school_admin)
  role         UserRole
  email        String   @unique
  phone        String?
  passwordHash String
  firstName    String
  lastName     String
  avatarUrl    String?
  language     Language @default(uz)
  isActive     Boolean  @default(true)
  coins        Int      @default(0)  // Gamification: student reward coins
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  school  School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  branch  Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)

  // Teacher relations
  taughtSubjects   Subject[]    @relation("TeacherSubjects")
  classTeacherOf   Class[]      @relation("ClassTeacher")
  scheduleSlots    Schedule[]   @relation("ScheduleTeacher")

  // Student relations
  studentClasses   ClassStudent[]
  attendance       Attendance[]
  grades           Grade[]
  payments         Payment[]
  submittedHomework HomeworkSubmission[]
  parentStudents   ParentStudent[] @relation("ParentUser")
  childParents     ParentStudent[] @relation("StudentUser")

  // Common
  sentMessages     Message[]    @relation("MessageSender")
  receivedMessages Message[]    @relation("MessageReceiver")
  notifications    Notification[]
  conversationsCreated    Conversation[]              @relation("ConversationCreator")
  conversationParticipants ConversationParticipant[]
  groupMessages           GroupMessage[]              @relation("GroupMessageSender")
  refreshTokens    RefreshToken[]
  auditLogs        AuditLog[]

  // Leave requests
  leaveRequests  LeaveRequest[]  @relation("LeaveRequests")
  leaveApprovals LeaveApproval[] @relation("LeaveApprovals")

  // Online exam sessions
  examSessions   ExamSession[]   @relation("ExamSessions")

  // Payroll
  staffSalary      StaffSalary?    @relation("StaffSalary")
  advanceRequests  SalaryAdvance[] @relation("AdvanceRequests")
  advanceApprovals SalaryAdvance[] @relation("AdvanceApprovals")
  payrollCreated   MonthlyPayroll[] @relation("PayrollCreator")
  payrollApproved  MonthlyPayroll[] @relation("PayrollApprover")
  payrollItems     PayrollItem[]   @relation("PayrollItems")
  createdEvents    AcademicEvent[] @relation("AcademicEventCreator")

  // Discipline
  disciplineAsStudent  DisciplineIncident[] @relation("DisciplineStudent")
  disciplineReported   DisciplineIncident[] @relation("DisciplineReporter")

  // Parent-Teacher Meetings
  meetingsAsTeacher  ParentMeeting[] @relation("MeetingTeacher")
  meetingsAsParent   ParentMeeting[] @relation("MeetingParent")
  meetingsAsStudent  ParentMeeting[] @relation("MeetingStudent")

  // Transport
  transportAssignments TransportStudent[] @relation("TransportStudent")

  // Learning Center
  coursesTeaching CourseEnrollment[] @relation("CourseStudent")
  coursesTaught   Course[]           @relation("CourseTeacher")

  // Clubs
  ledClubs         Club[]            @relation("ClubLeader")
  clubMembers      ClubMember[]      @relation("ClubMembers")
  clubJoinRequests ClubJoinRequest[] @relation("ClubJoinRequests")

  // Notification preferences (stored as JSON)
  notifPreferences Json?

  // Multi-branch assignments (teacher can teach in 2 branches)
  branchAssignments UserBranchAssignment[]

  // Financial shifts (kassir)
  openedShifts FinancialShift[] @relation("ShiftOpener")
  closedShifts FinancialShift[] @relation("ShiftCloser")

  // Course materials (yaratuvchi)
  courseMaterials CourseMaterial[] @relation("CourseMaterialCreator")

  // CRM leads
  assignedLeads   Lead[]        @relation("LeadAssignee")
  createdLeads    Lead[]        @relation("LeadCreator")
  leadComments    LeadComment[] @relation("LeadCommentAuthor")

  // Gamification
  coinTransactions CoinTransaction[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model ParentStudent {
  id        String @id @default(uuid())
  parentId  String
  studentId String

  parent  User @relation("ParentUser", fields: [parentId], references: [id], onDelete: Cascade)
  student User @relation("StudentUser", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([parentId, studentId])
  @@map("parent_students")
}

// ─── Classes ──────────────────────────────────────────────────────────────

model Class {
  id             String   @id @default(uuid())
  schoolId       String
  branchId       String?  // NULL = maktab umumiy sinfi (filial yo'q rejim)
  name           String
  gradeLevel     Int
  academicYear   String
  classTeacherId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  school       School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  branch       Branch?        @relation(fields: [branchId], references: [id], onDelete: SetNull)
  classTeacher User?          @relation("ClassTeacher", fields: [classTeacherId], references: [id])
  students     ClassStudent[]
  subjects     Subject[]
  schedules    Schedule[]
  attendance   Attendance[]
  grades       Grade[]
  exams        Exam[]
  homeworks    Homework[]

  @@map("classes")
}

model ClassStudent {
  id        String   @id @default(uuid())
  classId   String
  studentId String
  joinedAt  DateTime @default(now())

  class   Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  student User  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classId, studentId])
  @@map("class_students")
}

// ─── Subjects ─────────────────────────────────────────────────────────────

model Subject {
  id        String   @id @default(uuid())
  schoolId  String
  classId   String
  name      String
  teacherId String
  createdAt DateTime @default(now())

  school    School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class     Class      @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher   User       @relation("TeacherSubjects", fields: [teacherId], references: [id])
  schedules Schedule[]
  grades    Grade[]
  exams     Exam[]
  homeworks Homework[]

  @@map("subjects")
}

// ─── Schedule ─────────────────────────────────────────────────────────────

model Schedule {
  id         String    @id @default(uuid())
  schoolId   String
  branchId   String?   // Sinfning filiali (denormalized, konflikt tekshirish uchun)
  classId    String
  subjectId  String
  teacherId  String
  roomNumber String?   // Legacy: string xona raqami
  roomId     String?   // FK → Room (yangi: Room modeli bo'yicha)
  dayOfWeek  DayOfWeek
  timeSlot   Int
  startTime  String    // "HH:MM" — mahalliy vaqt (school.timezone)
  endTime    String    // "HH:MM" — mahalliy vaqt (school.timezone)
  // UTC minute offsets for cross-branch conflict detection
  // startDayMinUtc = dayOfWeek_index * 1440 + (startHour * 60 + startMin) - tzOffsetMinutes
  startDayMinUtc Int?  // Haftaning boshidan UTC minutlar soni
  endDayMinUtc   Int?  // Haftaning boshidan UTC minutlar soni
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  school     School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  branch     Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  class      Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject    Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher    User         @relation("ScheduleTeacher", fields: [teacherId], references: [id])
  room       Room?        @relation(fields: [roomId], references: [id], onDelete: SetNull)
  attendance Attendance[]

  @@index([schoolId, dayOfWeek])
  @@index([teacherId, dayOfWeek])
  @@index([branchId, dayOfWeek])
  @@map("schedules")
}

// ─── Attendance ───────────────────────────────────────────────────────────

model Attendance {
  id         String           @id @default(uuid())
  schoolId   String
  branchId   String?          // Denormalized from class — tezkor filtr uchun
  classId    String
  studentId  String
  scheduleId String?
  date       DateTime         @db.Date
  status     AttendanceStatus @default(present)
  note       String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  school   School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  branch   Branch?   @relation(fields: [branchId], references: [id], onDelete: SetNull)
  class    Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  student  User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  schedule Schedule? @relation(fields: [scheduleId], references: [id])

  @@unique([studentId, scheduleId, date])
  @@index([classId, date])
  @@index([schoolId, date])
  @@index([studentId])              // D-3: talaba tarixi O(1)
  @@index([schoolId, status])       // D-3: status bo'yicha filtr O(1)
  @@map("attendance")
}

// ─── Grades ───────────────────────────────────────────────────────────────

model Grade {
  id        String    @id @default(uuid())
  schoolId  String
  branchId  String?   // Denormalized from class — tezkor filtr uchun
  classId   String
  studentId String
  subjectId String
  type      GradeType
  score     Float
  maxScore  Float     @default(100)
  date      DateTime  @db.Date
  comment   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  branch  Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  student User    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([studentId, subjectId])
  @@index([classId, type])
  @@index([schoolId, date])         // D-3: chorak/sana filtr O(1)
  @@map("grades")
}

// ─── Exams (Phase 2 stub) ─────────────────────────────────────────────────

model Exam {
  id           String        @id @default(uuid())
  schoolId     String
  classId      String
  subjectId    String
  title        String
  frequency    ExamFrequency @default(on_demand)
  maxScore     Float         @default(100)
  scheduledAt  DateTime?
  duration     Int?
  isPublished  Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  school    School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class     Class          @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject   Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  questions ExamQuestion[]
  sessions  ExamSession[]

  @@map("exams")
}

// ─── Homework (Phase 2 stub) ──────────────────────────────────────────────

model Homework {
  id          String   @id @default(uuid())
  schoolId    String
  classId     String
  subjectId   String
  title       String
  description String?
  dueDate     DateTime
  createdAt   DateTime @default(now())

  school      School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class       Class                @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject     Subject              @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  submissions HomeworkSubmission[]

  @@map("homeworks")
}

model HomeworkSubmission {
  id          String   @id @default(uuid())
  homeworkId  String
  studentId   String
  content     String?
  fileUrl     String?
  score       Float?
  submittedAt DateTime @default(now())

  homework Homework @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  student  User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([homeworkId, studentId])
  @@map("homework_submissions")
}

// ─── Payments ─────────────────────────────────────────────────────────────

model Payment {
  id              String          @id @default(uuid())
  schoolId        String
  branchId        String?         // Filialga tegishli to'lov izolyatsiyasi
  studentId       String
  treasuryId      String?         // To'lov tushgan g'azna (Treasury)
  shiftId         String?         // Qaysi smena ichida qabul qilingan
  amount          Float
  currency        String          @default("UZS")
  status          PaymentStatus   @default(pending)
  provider        PaymentProvider @default(cash)
  providerOrderId String?
  description     String?
  dueDate         DateTime?
  paidAt          DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  school   School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  branch   Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)
  student  User            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  treasury Treasury?       @relation(fields: [treasuryId], references: [id], onDelete: SetNull)
  shift    FinancialShift? @relation(fields: [shiftId], references: [id], onDelete: SetNull)

  @@index([schoolId, status, dueDate])
  @@index([branchId, status])
  @@index([studentId, status])
  @@index([treasuryId])
  @@map("payments")
}

// ─── Fee Structures ───────────────────────────────────────────────────────

model FeeStructure {
  id           String   @id @default(uuid())
  schoolId     String
  name         String   @db.VarChar(200)
  description  String?
  amount       Float
  currency     String   @default("UZS")
  frequency    String   @default("monthly")
  gradeLevel   Int?
  academicYear String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("fee_structures")
}

// ─── Notifications ────────────────────────────────────────────────────────

model Notification {
  id          String              @id @default(uuid())
  schoolId    String
  recipientId String
  title       String
  body        String
  type        NotificationChannel @default(in_app)
  isRead      Boolean             @default(false)
  metadata    Json?
  createdAt   DateTime            @default(now())

  school    School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  recipient User   @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─── Messages ─────────────────────────────────────────────────────────────

model Message {
  id         String   @id @default(uuid())
  schoolId   String
  senderId   String
  receiverId String
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  sender   User   @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User   @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@map("messages")
}

// ─── Group Conversations ──────────────────────────────────────────────────

model Conversation {
  id          String   @id @default(uuid())
  schoolId    String
  name        String   // Group name (required for groups)
  description String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school       School                    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdBy    User                      @relation("ConversationCreator", fields: [createdById], references: [id])
  participants ConversationParticipant[]
  messages     GroupMessage[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String    @id @default(uuid())
  conversationId String
  userId         String
  isAdmin        Boolean   @default(false)
  joinedAt       DateTime  @default(now())
  lastReadAt     DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@map("conversation_participants")
}

model GroupMessage {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("GroupMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@map("group_messages")
}

// ─── Canteen (Phase 3 stub) ───────────────────────────────────────────────

model MenuDay {
  id        String   @id @default(uuid())
  schoolId  String
  date      DateTime @db.Date
  mealType  String
  itemsJson Json
  price     Float?
  createdAt DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, date, mealType])
  @@map("menu_days")
}

// ─── Library (Phase 3 stub) ───────────────────────────────────────────────

model LibraryBook {
  id              String   @id @default(uuid())
  schoolId        String
  isbn            String?
  title           String
  author          String?
  copiesTotal     Int      @default(1)
  copiesAvailable Int      @default(1)
  createdAt       DateTime @default(now())

  school School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  loans  LibraryLoan[]

  @@map("library_books")
}

model LibraryLoan {
  id         String    @id @default(uuid())
  schoolId   String
  bookId     String
  studentId  String
  loanDate   DateTime  @default(now())
  dueDate    DateTime
  returnDate DateTime?

  school School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  book   LibraryBook @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@map("library_loans")
}

// ─── Audit Log ────────────────────────────────────────────────────────────

model AuditLog {
  id         String      @id @default(uuid())
  schoolId   String?
  userId     String?
  action     AuditAction
  entity     String
  entityId   String?
  oldData    Json?
  newData    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  school School? @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([schoolId, createdAt(sort: Desc)])
  @@index([schoolId, entity])
  @@map("audit_logs")
}

// ─── Leave Requests ───────────────────────────────────────────────────────

enum LeaveStatus {
  pending
  approved
  rejected
  cancelled
}

model LeaveRequest {
  id          String      @id @default(uuid())
  schoolId    String
  branchId    String?     // Ta'til so'rovchisi qaysi filialda
  requesterId String
  reason      String
  startDate   DateTime    @db.Date
  endDate     DateTime    @db.Date
  status      LeaveStatus @default(pending)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  school    School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  branch    Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  requester User    @relation("LeaveRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  approvals LeaveApproval[]

  @@index([schoolId, status])       // D-2: status filtr O(1)
  @@index([requesterId])            // D-2: talaba/xodim so'rovlari O(1)
  @@index([schoolId, startDate])    // D-2: sana oralig'i qidirish
  @@map("leave_requests")
}

model LeaveApproval {
  id             String      @id @default(uuid())
  leaveRequestId String
  approverId     String
  status         LeaveStatus @default(pending)
  comment        String?
  decidedAt      DateTime?
  createdAt      DateTime    @default(now())

  leaveRequest LeaveRequest @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)
  approver     User         @relation("LeaveApprovals", fields: [approverId], references: [id], onDelete: Cascade)

  @@unique([leaveRequestId, approverId])
  @@map("leave_approvals")
}

// ─── Staff Salary & Payroll ───────────────────────────────────────────────

enum AdvanceStatus {
  pending
  approved
  rejected
  paid
}

// ─── Tarifikatsiya Enums ───────────────────────────────────────────────────

enum CalculationType {
  fixed           // Aniq belgilangan oylik
  tariff_based    // UZ tarif jadvaliga asoslangan
}

enum TeacherGrade {
  none            // Toifasiz
  second          // 2-toifa
  first           // 1-toifa
  highest         // Oliy toifa
}

enum AcademicDegree {
  none
  candidate       // Fan nomzodi (PhD)
  doctor          // Fan doktori
}

enum HonorificTitle {
  none
  methodist               // Metodist
  teacher_of_teachers     // O'qituvchilar o'qituvchisi
}

enum PayrollStatus {
  draft
  approved
  paid
}

model StaffSalary {
  id                   String          @id @default(uuid())
  schoolId             String
  branchId             String?         // Maosh qaysi filial byujetidan
  userId               String          @unique
  // ─ Hisoblash turi ─
  calculationType      CalculationType @default(fixed)
  // ─ Asosiy maosh ─
  baseSalary           Float
  hourlyRate           Float           @default(0)  // Asosiy dars soati narxi
  extraCurricularRate  Float           @default(0)  // To'garak soati narxi
  degreeAllowance      Float           @default(0)  // Ilmiy daraja qo'shimchasi (oylik)
  certificateAllowance Float           @default(0)  // Til sertifikati qo'shimchasi (oylik)
  currency             String          @default("UZS")
  position             String?
  startDate            DateTime        @db.Date
  isActive             Boolean         @default(true)
  // ─ Tarifikatsiya ma'lumotlari (UZ standartlari) ─
  qualificationGrade   TeacherGrade    @default(none)
  educationLevel       String?         // secondary_specialized | higher | master | doctoral
  workExperienceYears  Int             @default(0)
  academicDegree       AcademicDegree  @default(none)
  honorificTitle       HonorificTitle  @default(none)
  languageCerts        Json?           // [{type: "IELTS", score: "6.5", level: "C1", expiry: "2027-01-01"}]
  weeklyLessonHours    Int             @default(18) // Standart 18 soat/hafta
  // ─ Hisoblangan qiymatlar (tariff_based rejimida auto-fill) ─
  computedBaseSalary   Float?
  computedHourlyRate   Float?
  tariffBreakdownJson  Json?           // Hisob-kitob tafsilotlari
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  school       School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  branch       Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)
  user         User            @relation("StaffSalary", fields: [userId], references: [id], onDelete: Cascade)
  advances     SalaryAdvance[]
  payrollItems PayrollItem[]

  @@map("staff_salaries")
}

model SalaryAdvance {
  id            String        @id @default(uuid())
  schoolId      String
  staffSalaryId String
  userId        String
  amount        Float
  reason        String?
  month         Int
  year          Int
  status        AdvanceStatus @default(pending)
  approvedById  String?
  approvedAt    DateTime?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  school      School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  staffSalary StaffSalary @relation(fields: [staffSalaryId], references: [id], onDelete: Cascade)
  user        User        @relation("AdvanceRequests", fields: [userId], references: [id], onDelete: Cascade)
  approvedBy  User?       @relation("AdvanceApprovals", fields: [approvedById], references: [id], onDelete: SetNull)

  @@map("salary_advances")
}

model MonthlyPayroll {
  id          String        @id @default(uuid())
  schoolId    String
  month       Int
  year        Int
  status      PayrollStatus @default(draft)
  totalGross  Float         @default(0)
  totalNet    Float         @default(0)
  createdById String
  approvedById String?
  approvedAt  DateTime?
  paidAt      DateTime?
  note        String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  school      School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdBy   User          @relation("PayrollCreator", fields: [createdById], references: [id], onDelete: Cascade)
  approvedBy  User?         @relation("PayrollApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  items       PayrollItem[]

  @@unique([schoolId, month, year])
  @@map("monthly_payrolls")
}

model PayrollItem {
  id                    String   @id @default(uuid())
  schoolId              String
  payrollId             String
  staffSalaryId         String
  userId                String
  baseSalary            Float
  degreeAllowance       Float    @default(0)  // Snapshot from StaffSalary
  certificateAllowance  Float    @default(0)  // Snapshot from StaffSalary
  scheduledHours        Int      @default(0)
  completedHours        Int      @default(0)
  hourlyAmount          Float    @default(0)
  extraCurricularHours  Int      @default(0)
  extraCurricularAmount Float    @default(0)
  bonuses               Float    @default(0)
  deductions            Float    @default(0)
  grossTotal            Float
  advancePaid           Float    @default(0)
  netTotal              Float
  note                  String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  school      School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  payroll     MonthlyPayroll @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  staffSalary StaffSalary    @relation(fields: [staffSalaryId], references: [id], onDelete: Cascade)
  user        User           @relation("PayrollItems", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([payrollId, staffSalaryId])
  @@map("payroll_items")
}

// ─── Online Exam Platform ────────────────────────────────────────────────────

enum QuestionType {
  multiple_choice   // Ko'p tanlovli (A, B, C, D)
  true_false        // To'g'ri / Noto'g'ri
  short_answer      // Qisqa javob (matn)
  essay             // Insho / Keng javob
}

enum SessionStatus {
  not_started
  in_progress
  submitted
  timed_out
  graded
}

model ExamQuestion {
  id          String       @id @default(uuid())
  examId      String
  type        QuestionType @default(multiple_choice)
  text        String       // Savol matni
  points      Float        @default(1)
  order       Int          @default(0)
  mediaUrl    String?      // Rasm/audio URL (ixtiyoriy)
  explanation String?      // To'g'ri javob izohi
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  exam    Exam           @relation(fields: [examId], references: [id], onDelete: Cascade)
  options ExamOption[]
  answers StudentAnswer[]

  @@index([examId, order])
  @@map("exam_questions")
}

model ExamOption {
  id         String   @id @default(uuid())
  questionId String
  text       String
  isCorrect  Boolean  @default(false)
  order      Int      @default(0)

  question ExamQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers  StudentAnswer[]

  @@index([questionId])
  @@map("exam_options")
}

model ExamSession {
  id          String        @id @default(uuid())
  examId      String
  studentId   String
  schoolId    String
  startedAt   DateTime      @default(now())
  submittedAt DateTime?
  timedOutAt  DateTime?
  status      SessionStatus @default(in_progress)
  score       Float?        // Umumiy to'plangan ball
  percentage  Float?        // Foizda
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  exam    Exam          @relation(fields: [examId], references: [id], onDelete: Cascade)
  student User          @relation("ExamSessions", fields: [studentId], references: [id], onDelete: Cascade)
  school  School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  answers StudentAnswer[]

  @@unique([examId, studentId])
  @@index([examId, status])
  @@map("exam_sessions")
}

model StudentAnswer {
  id               String   @id @default(uuid())
  sessionId        String
  questionId       String
  selectedOptionId String?  // Ko'p tanlovli va true/false uchun
  textAnswer       String?  // Qisqa javob va insho uchun
  isCorrect        Boolean?
  pointsEarned     Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  session        ExamSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question       ExamQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOption ExamOption?  @relation(fields: [selectedOptionId], references: [id])

  @@unique([sessionId, questionId])
  @@map("student_answers")
}

// ─── System Config ────────────────────────────────────────────────────────────
// Global sozlamalar: BHM, tarif koeffitsientlari va boshqalar

model SystemConfig {
  id        String   @id @default(uuid())
  schoolId  String
  key       String
  value     Json
  label     String?
  updatedAt DateTime @updatedAt
  updatedBy String?

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, key])
  @@map("system_configs")
}

// ─── Academic Calendar ───────────────────────────────────────────────────────

enum AcademicEventType {
  holiday         // Ta'til
  exam_week       // Imtihon haftasi
  quarter_start   // Chorak boshlanishi
  quarter_end     // Chorak tugashi
  school_event    // Maktab tadbirи
  meeting         // Yig'ilish
  other
}

model AcademicEvent {
  id          String             @id @default(uuid())
  schoolId    String
  title       String
  description String?
  type        AcademicEventType  @default(other)
  startDate   DateTime
  endDate     DateTime
  allDay      Boolean            @default(true)
  color       String?            // hex color for frontend calendar
  createdById String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  school    School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdBy User   @relation("AcademicEventCreator", fields: [createdById], references: [id])

  @@index([schoolId, startDate])
  @@map("academic_events")
}

// ─── Discipline ───────────────────────────────────────────────────────────────

enum DisciplineType {
  behavior
  absence
  academic
  dress_code
  other
}

enum DisciplineSeverity {
  low
  medium
  high
}

enum DisciplineAction {
  warning
  detention
  parent_call
  parent_meeting
  suspension
  other
}

model DisciplineIncident {
  id           String             @id @default(uuid())
  schoolId     String
  studentId    String
  reportedById String
  type         DisciplineType     @default(other)
  severity     DisciplineSeverity @default(low)
  action       DisciplineAction   @default(warning)
  description  String
  date         DateTime           @db.Date
  resolved     Boolean            @default(false)
  resolvedAt   DateTime?
  notes        String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  school     School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student    User   @relation("DisciplineStudent", fields: [studentId], references: [id], onDelete: Cascade)
  reportedBy User   @relation("DisciplineReporter", fields: [reportedById], references: [id], onDelete: Cascade)

  @@index([schoolId, date])
  @@index([studentId])
  @@map("discipline_incidents")
}

// ─── Parent-Teacher Meetings ──────────────────────────────────────────────────

enum MeetingStatus {
  scheduled
  completed
  cancelled
}

enum MeetingMedium {
  in_person
  phone
  video
}

model ParentMeeting {
  id          String        @id @default(uuid())
  schoolId    String
  teacherId   String
  parentId    String
  studentId   String
  scheduledAt DateTime
  duration    Int           @default(30)  // minutes
  medium      MeetingMedium @default(in_person)
  status      MeetingStatus @default(scheduled)
  agenda      String?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  school  School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher User   @relation("MeetingTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  parent  User   @relation("MeetingParent", fields: [parentId], references: [id], onDelete: Cascade)
  student User   @relation("MeetingStudent", fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId, scheduledAt])
  @@index([teacherId])
  @@index([parentId])
  @@map("parent_meetings")
}

// ─── Transport ───────────────────────────────────────────────────────────────

model TransportRoute {
  id             String   @id @default(uuid())
  schoolId       String
  branchId       String?  // Transport qaysi filialga xizmat qiladi
  name           String
  description    String?
  stops          Json     @default("[]") // string[]
  departureTime  String   // "07:30"
  arrivalTime    String   // "08:15"
  driverName     String?
  driverPhone    String?
  vehicleNumber  String?
  capacity       Int      @default(30)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  school       School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  branch       Branch?            @relation(fields: [branchId], references: [id], onDelete: SetNull)
  assignments  TransportStudent[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@index([branchId])
  @@map("transport_routes")
}

model TransportStudent {
  id        String   @id @default(uuid())
  schoolId  String
  routeId   String
  studentId String
  stopName  String?
  createdAt DateTime @default(now())

  school  School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  route   TransportRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  student User           @relation("TransportStudent", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([routeId, studentId])
  @@index([schoolId])
  @@index([studentId])
  @@map("transport_students")
}

// ─── Learning Center ─────────────────────────────────────────────────────────

model Course {
  id          String      @id @default(uuid())
  schoolId    String
  branchId    String?     // Qaysi filialda o'qitiladi (LOCAL uchun talab qilinadi)
  scope       CourseScope @default(GLOBAL)  // GLOBAL = barcha filiallar, LOCAL = faqat shu filial
  name        String
  description String?
  teacherId   String?
  duration    Int?        // weeks
  price       Float?
  maxStudents Int         @default(30)
  isActive    Boolean     @default(true)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  school      School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  branch      Branch?           @relation(fields: [branchId], references: [id], onDelete: SetNull)
  teacher     User?             @relation("CourseTeacher", fields: [teacherId], references: [id])
  enrollments CourseEnrollment[]
  materials   CourseMaterial[]

  @@index([schoolId])
  @@index([branchId])
  @@index([schoolId, scope])
  @@map("courses")
}

// ─── Course Materials (Shared — schoolId bo'yicha, branchdan mustaqil) ─────
// Har qaysi filial o'qituvchisi maktabning markaziy materiallariga kira oladi.

model CourseMaterial {
  id          String   @id @default(uuid())
  schoolId    String   // schoolId-ga bog'liq — filialga emas. Barcha filial o'qituvchilari ko'ra oladi.
  courseId    String
  title       String
  description String?
  fileUrl     String?
  type        String   @default("document")  // document | video | link | pdf | audio
  isPublic    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdById String?  // Qaysi o'qituvchi qo'shgan
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school     School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  course     Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdBy  User?   @relation("CourseMaterialCreator", fields: [createdById], references: [id])

  @@index([schoolId])
  @@index([courseId])
  @@map("course_materials")
}

model CourseEnrollment {
  id         String   @id @default(uuid())
  schoolId   String
  courseId   String
  studentId  String
  enrolledAt DateTime @default(now())
  status     String   @default("active") // active | completed | dropped
  grade      Float?
  notes      String?

  school  School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student User   @relation("CourseStudent", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([courseId, studentId])
  @@index([schoolId])
  @@index([studentId])
  @@map("course_enrollments")
}

// ─── Clubs (To'garaklar) ─────────────────────────────────────────────────────

model Club {
  id                String       @id @default(uuid())
  schoolId          String
  branchId          String?      // Qaysi filialda ishlaydi
  name              String
  description       String?
  category          ClubCategory @default(other)
  leaderId          String
  schedule          String?      // Display string e.g. "Chorshanba 15:00-16:00"
  scheduleDays      DayOfWeek[]  // Structured: days of week club meets
  scheduleStartTime String?      // "15:00"
  scheduleEndTime   String?      // "16:00"
  maxMembers        Int?
  isActive          Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  school       School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  branch       Branch?           @relation(fields: [branchId], references: [id], onDelete: SetNull)
  leader       User              @relation("ClubLeader", fields: [leaderId], references: [id])
  members      ClubMember[]
  joinRequests ClubJoinRequest[]

  @@index([schoolId])
  @@index([branchId])
  @@map("clubs")
}

model ClubMember {
  id        String   @id @default(uuid())
  clubId    String
  studentId String
  joinedAt  DateTime @default(now())

  club    Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  student User @relation("ClubMembers", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([clubId, studentId])
  @@index([studentId])
  @@map("club_members")
}

model ClubJoinRequest {
  id        String            @id @default(uuid())
  clubId    String
  studentId String
  status    ClubRequestStatus @default(PENDING)
  message   String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  club    Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  student User @relation("ClubJoinRequests", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([clubId, studentId])
  @@index([studentId])
  @@index([clubId, status])
  @@map("club_join_requests")
}

// ─── Treasury (G'azna / Kassa) ────────────────────────────────────────────
// CENTRALIZED  → schoolId bo'yicha bitta umumiy g'azna (branchId = null)
// DECENTRALIZED → har bir filialning o'z g'aznasi (branchId SET)

model Treasury {
  id        String       @id @default(uuid())
  schoolId  String
  branchId  String?      // null = markaziy (CENTRALIZED), SET = filial kassasi
  name      String                     // "Asosiy kassa", "Chilonzor naqd"
  type      TreasuryType @default(CASH)
  balance   Float        @default(0)   // Hozirgi balans (UZS)
  currency  String       @default("UZS")
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  school   School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  payments        Payment[]
  financialShifts FinancialShift[]

  @@index([schoolId, branchId])
  @@index([schoolId, type])
  @@map("treasuries")
}

// ─── Financial Shift (Kassir smenasi) ────────────────────────────────────
// O'quv markazlari (DECENTRALIZED) uchun kunlik kassa smenasini boshqarish.
// To'lov qabul qilish uchun ochiq smena bo'lishi shart.

model FinancialShift {
  id               String      @id @default(uuid())
  schoolId         String
  branchId         String?
  treasuryId       String
  openerId         String                        // Smenani ochgan xodim
  closerId         String?                       // Smenani yopgan xodim
  startTime        DateTime    @default(now())
  endTime          DateTime?
  startingBalance  Float       @default(0)       // Smena boshidagi balans
  expectedBalance  Float?      // Hisoblangan kutilgan balans (startingBalance + to'lovlar)
  actualBalance    Float?      // Kassir hisoblagan haqiqiy balans
  discrepancy      Float?      // expectedBalance - actualBalance (farq)
  status           ShiftStatus @default(OPEN)
  notes            String?     // Kassir izohi
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  school   School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  branch   Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  treasury Treasury @relation(fields: [treasuryId], references: [id], onDelete: Cascade)
  opener   User     @relation("ShiftOpener", fields: [openerId], references: [id])
  closer   User?    @relation("ShiftCloser", fields: [closerId], references: [id])

  payments Payment[]

  @@index([schoolId, status])
  @@index([branchId, status])
  @@index([treasuryId, status])
  @@map("financial_shifts")
}

// ─── Rooms (Darsxonalar) ──────────────────────────────────────────────────
// Xona har doim bitta filialga tegishli (branchId required).
// Konflikt tekshirishda xona faqat o'sha filial doirasida tekshiriladi.

model Room {
  id        String   @id @default(uuid())
  schoolId  String
  branchId  String   // Required — xona har doim bitta filialga tegishli
  name      String   // "201-xona", "Fizika lab", "Sport zal"
  capacity  Int      @default(30)
  floor     Int?     // Qavat raqami
  type      String   @default("classroom")  // classroom | lab | hall | gym | other
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school    School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  branch    Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  schedules Schedule[]

  @@unique([schoolId, branchId, name])
  @@index([schoolId, branchId])
  @@map("rooms")
}

// ─── CRM: Leads (Potensial o'quvchilar) ───────────────────────────────────────
//
// Voronka:  NEW → CONTACTED → TEST_LESSON → WAITING_PAYMENT → CONVERTED / CLOSED
//
// Duplicate aniqlash:
//   phone + schoolId kombinatsiyasi UNIQUE — bir telefon bir maktabda faqat 1 marta.
//   Agar bitta odam Instagram + Telegram orqali yozsa → birinchi leadni qayta-ishlatamiz
//   (source + note yangilanadi, yangi lead yarATILMAYDI).
//
// convertToStudent():
//   Lead → User (student) + ClassStudent → Lead.status = CONVERTED
//   Prisma.$transaction ichida atomik.

model Lead {
  id                 String     @id @default(uuid())
  schoolId           String
  branchId           String?    // Qaysi filialgaa tegishli (NULL = umumiy / filial aniqlanmagan)
  firstName          String
  lastName           String
  phone              String     // Asosiy identifikator (duplicate tekshirish uchun)
  source             LeadSource @default(OTHER)
  status             LeadStatus @default(NEW)
  note               String?    // Qo'shimcha izoh
  assignedToId       String?    // Mas'ul xodim (manager, reception, teacher)
  createdById        String?    // Kimn tomonidan yaratilgan
  convertedStudentId String?    // convertToStudent() dan keyin to'ldiriladi
  expectedClassId    String?    // Qaysi sinfga/guruhga mo'ljallangan
  nextContactDate    DateTime?  // Keyingi bog'lanish sanasi (reminder uchun)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  school     School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  branch     Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  assignedTo User?    @relation("LeadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy  User?    @relation("LeadCreator",  fields: [createdById], references: [id],  onDelete: SetNull)

  comments LeadComment[]

  // phone + schoolId — bir maktabda bitta telefon faqat bitta lead
  @@unique([schoolId, phone])
  @@index([schoolId, status])
  @@index([schoolId, branchId])
  @@index([schoolId, source])
  @@index([assignedToId])
  @@map("leads")
}

// ─── CRM: Lead izohlari (muloqot tarixi) ──────────────────────────────────────

model LeadComment {
  id        String   @id @default(uuid())
  leadId    String
  schoolId  String
  authorId  String?  // Izoh yozgan xodim
  text      String
  createdAt DateTime @default(now())

  lead   Lead   @relation(fields: [leadId],   references: [id], onDelete: Cascade)
  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  author User?  @relation("LeadCommentAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([schoolId])
  @@map("lead_comments")
}

// ─── Gamification: Coin tranzaksiyalari ───────────────────────────────────────

model CoinTransaction {
  id        String   @id @default(uuid())
  userId    String
  schoolId  String
  amount    Int
  type      String   // 'earn' | 'deduct'
  reason    String   // 'grade_excellent' | 'attendance_weekly' | 'discipline_praise' | 'manual_award' | 'discipline_warning' | 'shop_purchase'
  balance   Int      // Tranzaksiyadan keyingi balans
  metadata  Json?
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId],   references: [id], onDelete: Cascade)
  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([schoolId])
  @@index([userId, schoolId])
  @@map("coin_transactions")
}

model CoinShopItem {
  id          String   @id @default(uuid())
  schoolId    String
  name        String
  description String?
  cost        Int
  emoji       String?
  stock       Int?     // null = cheksiz
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("coin_shop_items")
}
