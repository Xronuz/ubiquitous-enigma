# ═══════════════════════════════════════════════════════════════════════════════
# EduPlatform — Caddyfile (HTTP rejimi)
#
# Hozir: auto_https off — faqat port 80, TLS yo'q
# Keyinroq HTTPS yoqish uchun:
#   1. Cloudflare DNS: platform.cybertron.uz → 185.197.249.26
#   2. docker-compose da 443:443 portni ochish
#   3. Bu fayldagi "auto_https off" ni o'chirish
#
# Saytlar:
#   platform.cybertron.uz (va 185.197.249.26) → Maktab boshqaruv tizimi
#   workload.cybertron.uz                      → PM2 loyiha (WORKLOAD_PORT)
#
# Rate limiting: NestJS ThrottlerModule (THROTTLE_TTL/THROTTLE_LIMIT)
# ═══════════════════════════════════════════════════════════════════════════════

{
    # HTTPS YOQILMAGAN — Let's Encrypt so'rov yo'q, 443 port bind yo'q
    # DNS va 443 port tayyor bo'lgach bu qatorni o'chirib tashlang
    auto_https off

    # HTTP/1.1 va HTTP/2 (HTTP/3 HTTPS kerak)
    servers {
        protocols h1 h2
    }
}

# ═══════════════════════════════════════════════════════════════════════════════
# MAKTAB BOSHQARUV TIZIMI — port 80
# platform.cybertron.uz va 185.197.249.26 IP orqali ham ishlaydi
# ═══════════════════════════════════════════════════════════════════════════════
:80 {

    # ── Xavfsizlik sarlavhalari ──────────────────────────────────────────────
    header {
        X-Frame-Options             "SAMEORIGIN"
        X-Content-Type-Options      "nosniff"
        X-XSS-Protection            "1; mode=block"
        Referrer-Policy             "strict-origin-when-cross-origin"
        # Server nomini yashirish
        -Server
    }

    # ── Fayl yuklash hajmi limiti (50MB) ─────────────────────────────────────
    request_body {
        max_size 50MB
    }

    # ── Siqish ───────────────────────────────────────────────────────────────
    encode zstd gzip

    # ── Workload loyihasi (PM2) ───────────────────────────────────────────────
    # Host: workload.cybertron.uz → 172.17.0.1:WORKLOAD_PORT (docker bridge)
    @workload host workload.cybertron.uz
    handle @workload {
        reverse_proxy 172.17.0.1:{$WORKLOAD_PORT:-3500} {
            header_up X-Real-IP {http.request.remote.host}
            header_up Host      {http.request.host}
        }
    }

    # ─────────────────────────────────────────────────────────────────────────
    # MAKTAB BOSHQARUV — qolgan barcha so'rovlar (IP va platform.cybertron.uz)
    # ─────────────────────────────────────────────────────────────────────────

    # ── 1. Health check ───────────────────────────────────────────────────────
    @health path /api/health
    handle @health {
        reverse_proxy backend:3001
    }

    # ── 2. Auth endpointlar — /api/v1/auth/* ─────────────────────────────────
    @auth path /api/v1/auth/*
    handle @auth {
        reverse_proxy backend:3001 {
            header_up X-Real-IP {http.request.remote.host}
            header_up Host      {http.request.host}
            transport http {
                response_header_timeout 30s
            }
        }
    }

    # ── 3. Umumiy API — /api/* ────────────────────────────────────────────────
    @api path /api/*
    handle @api {
        reverse_proxy backend:3001 {
            header_up X-Real-IP {http.request.remote.host}
            header_up Host      {http.request.host}
            transport http {
                response_header_timeout 60s
            }
        }
    }

    # ── 4. WebSocket / Socket.io ─────────────────────────────────────────────
    @websocket {
        path    /socket.io/*
        header  Connection *Upgrade*
        header  Upgrade    websocket
    }
    handle @websocket {
        reverse_proxy backend:3001 {
            header_up Connection {http.request.header.Connection}
            header_up Upgrade    {http.request.header.Upgrade}
            header_up Host       {http.request.host}
            transport http {
                read_timeout  0s
                write_timeout 0s
            }
        }
    }

    # ── 5. Next.js statik fayllar — 1 yil immutable kesh ────────────────────
    @static path /_next/static/*
    handle @static {
        header Cache-Control "public, max-age=31536000, immutable"
        reverse_proxy frontend:3000
    }

    # ── 6. Rasm optimizatsiyasi — 7 kun kesh ─────────────────────────────────
    @images path /_next/image*
    handle @images {
        header Cache-Control "public, max-age=604800"
        reverse_proxy frontend:3000 {
            header_up Host {http.request.host}
        }
    }

    # ── 7. Yuklangan fayllar — 7 kun kesh ────────────────────────────────────
    @uploads path /uploads/*
    handle @uploads {
        header Cache-Control "public, max-age=604800"
        reverse_proxy backend:3001 {
            header_up Host {http.request.host}
        }
    }

    # ── 8. Frontend — catch-all ───────────────────────────────────────────────
    handle {
        reverse_proxy frontend:3000 {
            header_up X-Real-IP {http.request.remote.host}
            header_up Host      {http.request.host}
            transport http {
                response_header_timeout 30s
            }
        }
    }

    # ── Loglash ──────────────────────────────────────────────────────────────
    log {
        output file /var/log/caddy/access.log {
            roll_size 10mb
            roll_keep 5
        }
        format json
        level  INFO
    }
}
