# ═══════════════════════════════════════════════════════════════════════════════
# EduPlatform — Caddyfile
#
# Saytlar:
#   platform.cybertron.uz   → Maktab boshqaruv tizimi
#                             (Docker: frontend:3000 + backend:3001)
#
#   workload.cybertron.uz   → PM2 da ishlaydigan loyiha
#                             (Host: host.docker.internal:WORKLOAD_PORT)
#
# TLS / HTTPS:
#   Caddy Let's Encrypt dan avtomatik sertifikat oladi.
#   HTTP port 80 → HTTPS port 443 ga yo'naltirish ham avtomatik.
#   /data volume ga sertifikatlar saqlanadi (docker-compose da mount qilingan).
#
# Rate limiting:
#   Proxy darajasida: Caddy built-in yo'q (xcaddy bilan yoqish mumkin)
#   Ilova darajasida: NestJS ThrottlerModule (THROTTLE_TTL/THROTTLE_LIMIT env)
#
# Konfiguratsiya o'zgaruvchilari (.env faylida o'rnating):
#   WORKLOAD_PORT  — PM2 loyihasi porti (standart: 3500)
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Global sozlamalar ────────────────────────────────────────────────────────
{
    # HTTP/1.1, HTTP/2 va HTTP/3 (QUIC) ni qabul qilish
    servers {
        protocols h1 h2 h3
    }

    # Let's Encrypt xato bildirishnomasi uchun email (ixtiyoriy, tavsiya etiladi)
    # email admin@cybertron.uz
}

# ═══════════════════════════════════════════════════════════════════════════════
# 1. MAKTAB BOSHQARUV TIZIMI — platform.cybertron.uz
# ═══════════════════════════════════════════════════════════════════════════════
platform.cybertron.uz {

    # ── Umumiy xavfsizlik sarlavhalari (barcha javoblarga qo'shiladi) ─────────
    header {
        # Iframe orqali saytni boshqalardan ko'rsatishni bloklash
        X-Frame-Options             "SAMEORIGIN"
        # MIME type sniffing hujumlaridan himoya
        X-Content-Type-Options      "nosniff"
        # Eski brauzerlarda XSS filtrni yoqish
        X-XSS-Protection            "1; mode=block"
        # Referer sarlavhasida faqat origin qoldirish
        Referrer-Policy             "strict-origin-when-cross-origin"
        # HSTS: 1 yil davomida faqat HTTPS orqali muloqot
        Strict-Transport-Security   "max-age=31536000; includeSubDomains"
        # Server nomini yashirish (fingerprinting oldini olish)
        -Server
    }

    # ── Fayl yuklash hajmi limiti (rasm/hujjat uchun 50MB) ───────────────────
    request_body {
        max_size 50MB
    }

    # ── Siqish (zstd > gzip) ─────────────────────────────────────────────────
    encode zstd gzip

    # ─────────────────────────────────────────────────────────────────────────
    # ROUTELAR (yuqoridan pastga — eng aniq avval)
    # ─────────────────────────────────────────────────────────────────────────

    # ── 1. Health check ───────────────────────────────────────────────────────
    @health path /api/health
    handle @health {
        reverse_proxy backend:3001
    }

    # ── 2. Auth endpointlar (/api/v1/auth/*) ─────────────────────────────────
    # Rate limiting: NestJS ThrottlerModule tomonidan boshqariladi
    @auth path /api/v1/auth/*
    handle @auth {
        reverse_proxy backend:3001 {
            header_up X-Real-IP         {http.request.remote.host}
            header_up X-Forwarded-For   {http.request.remote.host}
            header_up X-Forwarded-Proto {http.request.scheme}
            header_up Host              {http.request.host}
            # Auth so'rovlari uchun vaqt chegarasi: 30 soniya
            timeout 30s
        }
    }

    # ── 3. Umumiy API (/api/*) ────────────────────────────────────────────────
    # Rate limiting: NestJS ThrottlerModule tomonidan boshqariladi
    @api path /api/*
    handle @api {
        reverse_proxy backend:3001 {
            header_up X-Real-IP         {http.request.remote.host}
            header_up X-Forwarded-For   {http.request.remote.host}
            header_up X-Forwarded-Proto {http.request.scheme}
            header_up Host              {http.request.host}
            timeout 60s
        }
    }

    # ── 4. WebSocket / Socket.io — real-time ulanish ─────────────────────────
    # Xabar almashish, bildirishnomalar va h.k. uchun
    @websocket {
        path    /socket.io/*
        header  Connection *Upgrade*
        header  Upgrade    websocket
    }
    handle @websocket {
        reverse_proxy backend:3001 {
            header_up Connection {http.request.header.Connection}
            header_up Upgrade    {http.request.header.Upgrade}
            header_up Host       {http.request.host}
            # WebSocket ulanishi uzoq ochiq turishi kerak — timeout o'chiriladi
            transport http {
                read_timeout  0s
                write_timeout 0s
            }
        }
    }

    # ── 5. Next.js statik fayllar — 1 yil kesh (immutable) ──────────────────
    @static path /_next/static/*
    handle @static {
        header Cache-Control "public, max-age=31536000, immutable"
        reverse_proxy frontend:3000
    }

    # ── 6. Next.js rasm optimizatsiyasi — 7 kun kesh ─────────────────────────
    @images path /_next/image*
    handle @images {
        header Cache-Control "public, max-age=604800"
        reverse_proxy frontend:3000 {
            header_up Host {http.request.host}
        }
    }

    # ── 7. Yuklangan fayllar (rasm/PDF/hujjatlar) — 7 kun kesh ──────────────
    @uploads path /uploads/*
    handle @uploads {
        header Cache-Control "public, max-age=604800"
        reverse_proxy backend:3001 {
            header_up Host {http.request.host}
        }
    }

    # ── 8. Frontend (Next.js) — barcha qolgan so'rovlar ─────────────────────
    handle {
        reverse_proxy frontend:3000 {
            header_up X-Real-IP         {http.request.remote.host}
            header_up X-Forwarded-For   {http.request.remote.host}
            header_up X-Forwarded-Proto {http.request.scheme}
            header_up Host              {http.request.host}
            timeout 30s
        }
    }

    # ── Loglash ──────────────────────────────────────────────────────────────
    log {
        output file /var/log/caddy/platform.log {
            roll_size 10mb
            roll_keep 5
        }
        format json
        level  INFO
    }
}

# ═══════════════════════════════════════════════════════════════════════════════
# 2. WORKLOAD LOYIHASI — workload.cybertron.uz
#
# Bu loyiha server hostida PM2 orqali ishlaydi (Docker tashqarisida).
# Caddy → host.docker.internal:WORKLOAD_PORT orqali yo'naltiradi.
#
# SOZLASH: Server .env faylida qo'shing:
#   WORKLOAD_PORT=<pm2_loyiha_porti>   # masalan: 8080, 5000, 4000
#
# Linux da host.docker.internal ishlashi uchun docker-compose da:
#   extra_hosts: ["host.docker.internal:host-gateway"]  (allaqachon qo'shilgan)
# ═══════════════════════════════════════════════════════════════════════════════
workload.cybertron.uz {

    # ── Xavfsizlik sarlavhalari ──────────────────────────────────────────────
    header {
        X-Frame-Options             "SAMEORIGIN"
        X-Content-Type-Options      "nosniff"
        X-XSS-Protection            "1; mode=block"
        Referrer-Policy             "strict-origin-when-cross-origin"
        Strict-Transport-Security   "max-age=31536000"
        -Server
    }

    # ── Siqish ───────────────────────────────────────────────────────────────
    encode zstd gzip

    # ── WebSocket qo'llab-quvvatlash (agar PM2 loyiha WebSocket ishlatsa) ────
    @ws {
        header Connection *Upgrade*
        header Upgrade    websocket
    }
    handle @ws {
        reverse_proxy host.docker.internal:{$WORKLOAD_PORT:-3500} {
            header_up Connection {http.request.header.Connection}
            header_up Upgrade    {http.request.header.Upgrade}
            transport http {
                read_timeout  0s
                write_timeout 0s
            }
        }
    }

    # ── PM2 loyihasiga barcha so'rovlar ──────────────────────────────────────
    # host.docker.internal = Docker konteyneridan host mashinasiga murojaat
    # {$WORKLOAD_PORT:-3500} = WORKLOAD_PORT env o'zgaruvchisi, standart 3500
    handle {
        reverse_proxy host.docker.internal:{$WORKLOAD_PORT:-3500} {
            header_up X-Real-IP         {http.request.remote.host}
            header_up X-Forwarded-For   {http.request.remote.host}
            header_up X-Forwarded-Proto {http.request.scheme}
            header_up Host              {http.request.host}
        }
    }

    # ── Loglash ──────────────────────────────────────────────────────────────
    log {
        output file /var/log/caddy/workload.log {
            roll_size 10mb
            roll_keep 5
        }
        format json
        level  INFO
    }
}
